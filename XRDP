#!/bin/bash

# Colors for UI
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Function to display header
display_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}${BOLD}         XRDP & XFCE4 INSTALLER         ${NC}${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════╝${NC}"
    echo ""
}

# Function to check XRDP status
check_status() {
    if command -v xrdp &> /dev/null; then
        if systemctl is-active --quiet xrdp; then
            echo -e "Status: ${GREEN}${BOLD}INSTALLED & RUNNING${NC}"
        else
            echo -e "Status: ${YELLOW}${BOLD}INSTALLED (NOT RUNNING)${NC}"
        fi
    else
        echo -e "Status: ${RED}${BOLD}NOT INSTALLED${NC}"
    fi
}

# Function to install XRDP and Xfce4
install_xrdp() {
    echo -e "\n${BLUE}${BOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}${BOLD}║         INSTALLING XRDP & XFCE4          ║${NC}"
    echo -e "${BLUE}${BOLD}╚══════════════════════════════════════════╝${NC}"
    
    echo -e "\n${YELLOW}Step 1: Updating system repositories...${NC}"
    sudo apt update -y
    
    echo -e "\n${YELLOW}Step 2: Installing Xfce4 and XRDP packages...${NC}"
    if sudo apt install xfce4 xfce4-goodies xrdp -y; then
        echo -e "${GREEN}✓ Packages installed successfully${NC}"
    else
        echo -e "${RED}✗ Package installation failed${NC}"
        return 1
    fi
    
    echo -e "\n${YELLOW}Step 3: Configuring environment for the current user...${NC}"
    echo "xfce4-session" > ~/.xsession
    echo -e "${GREEN}✓ User session profile configured${NC}"
    
    echo -e "\n${YELLOW}Step 4: Granting certificate permissions to XRDP...${NC}"
    sudo adduser xrdp ssl-cert
    echo -e "${GREEN}✓ Group permissions updated${NC}"
    
    echo -e "\n${YELLOW}Step 5: Enabling and restarting XRDP service...${NC}"
    sudo systemctl enable xrdp
    sudo systemctl restart xrdp
    echo -e "${GREEN}✓ Service restarted and enabled${NC}"
    
    echo -e "\n${YELLOW}Step 6: Opening firewall port 3389...${NC}"
    if command -v ufw &> /dev/null; then
        sudo ufw allow 3389/tcp
        echo -e "${GREEN}✓ Firewall rule added (Port 3389/TCP)${NC}"
    else
        echo -e "${CYAN}i UFW firewall not detected, skipping port configuration${NC}"
    fi
    
    echo -e "\n${GREEN}${BOLD}═════════════════════════════════════════════${NC}"
    echo -e "${GREEN}${BOLD}✅ XRDP & XFCE4 INSTALLATION COMPLETE!${NC}"
    echo -e "${GREEN}${BOLD}═════════════════════════════════════════════${NC}"
}

# Function to uninstall XRDP and Xfce4
uninstall_xrdp() {
    echo -e "\n${RED}${BOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${RED}${BOLD}║        UNINSTALLING XRDP & XFCE4         ║${NC}"
    echo -e "${RED}${BOLD}╚══════════════════════════════════════════╝${NC}"
    
    echo -e "\n${RED}⚠ WARNING: This will completely remove XRDP,${NC}"
    echo -e "${RED}   the Xfce4 desktop, and all configuration files.${NC}"
    echo ""
    
    read -p "Are you sure? (yes/no): " confirm
    if [[ ! $confirm =~ ^[Yy][Ee]?[Ss]?$ ]]; then
        echo -e "\n${GREEN}Cancelled. XRDP was NOT removed.${NC}"
        return
    fi
    
    echo -e "\n${YELLOW}Step 1: Stopping XRDP service...${NC}"
    sudo systemctl stop xrdp
    sudo systemctl disable xrdp
    echo -e "${GREEN}✓ Service stopped${NC}"
    
    echo -e "\n${YELLOW}Step 2: Removing packages...${NC}"
    sudo apt purge xrdp xfce4 xfce4-goodies -y
    echo -e "${GREEN}✓ Packages removed${NC}"
    
    echo -e "\n${YELLOW}Step 3: Cleaning up configuration files...${NC}"
    sudo rm -rf /etc/xrdp /var/log/xrdp.log
    rm -f ~/.xsession
    echo -e "${GREEN}✓ Files cleaned${NC}"
    
    echo -e "\n${YELLOW}Step 4: Closing firewall port 3389...${NC}"
    if command -v ufw &> /dev/null; then
        sudo ufw delete allow 3389/tcp
        echo -e "${GREEN}✓ Firewall rule removed${NC}"
    fi
    
    echo -e "\n${YELLOW}Step 5: Removing unused dependencies...${NC}"
    sudo apt autoremove -y
    echo -e "${GREEN}✓ Dependencies removed${NC}"
    
    echo -e "\n${RED}${BOLD}═════════════════════════════════════════════${NC}"
    echo -e "${RED}${BOLD}🗑️  XRDP & XFCE4 COMPLETELY REMOVED!${NC}"
    echo -e "${RED}${BOLD}═════════════════════════════════════════════${NC}"
}

# Main menu
while true; do
    display_header
    check_status
    echo ""
    echo -e "${BOLD}══════════════════════════════════════════${NC}"
    echo -e "  ${GREEN}[1]${NC} ${BOLD}📥 Install XRDP & XFCE4${NC}"
    echo -e "  ${RED}[2]${NC} ${BOLD}🗑️  Uninstall XRDP & XFCE4${NC}"
    echo -e "  ${YELLOW}[3]${NC} ${BOLD}🚪 Exit${NC}"
    echo -e "${BOLD}══════════════════════════════════════════${NC}"
    echo ""
    
    read -p "Select option [1-3]: " option
    
    case $option in
        1)
            install_xrdp
            ;;
        2)
            uninstall_xrdp
            ;;
        3)
            echo -e "\n${CYAN}${BOLD}Thanks for using afnazz xrdp!${NC}\n"
            exit 0
            ;;
        *)
            echo -e "\n${RED}Invalid option! Choose 1, 2, or 3${NC}"
            ;;
    esac
    
    echo ""
    read -p "Press Enter to continue..."
done
